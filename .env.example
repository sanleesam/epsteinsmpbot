# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# Optional: Server ID for faster slash command registration during testing
# Commands register globally by default (can take up to 1 hour)
# Uncomment and add your server/guild ID for instant testing:
# GUILD_ID=1234567890

# Minecraft Server Configuration
MINECRAFT_SERVER_IP=drive-unawake.gl.joinmc.link
MINECRAFT_SERVER_PORT=25565

# Channel Configuration
ANNOUNCEMENT_CHANNEL_ID=1234567890
STATUS_CHANNEL_ID=1234567890
STATUS_MESSAGE_CHANNEL_ID=1234567890  # Channel where auto-updating status embed will be sent

# Other Configuration
NODE_ENV=development
